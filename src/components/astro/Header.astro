---
import { getRelativeLocaleUrl } from 'astro:i18n';

import { LocaleToggle } from '~/components/islands/locale-toggle';
import { MobileNav, NavLinks } from '~/components/islands/navlinks';
import { ThemeToggle } from '~/components/islands/theme-toggle';

import { getProjects } from '~/lib/projects';
import { createScopedTranslator, normalizeLocale } from '~/locales';

const locale = normalizeLocale(Astro.currentLocale);
const t = createScopedTranslator(locale, 'navbar');
const tTheme = createScopedTranslator(locale, 'theme_toggle');

const showProjects = (await getProjects(locale)).length > 0;

const navLabels = {
  scholarship: t('links.scholarship'),
  skills: t('links.skills'),
  job: t('links.job'),
  contact: t('links.contact'),
  projects: t('links.projects'),
};

const localeLabels = {
  label: t('locales.label'),
  fr: t('locales.fr'),
  en: t('locales.en'),
};

const themeLabels = {
  light: tTheme('light'),
  dark: tTheme('dark'),
  system: tTheme('system'),
};

const homePath = getRelativeLocaleUrl(locale, '/');
const logoSrc = '/assets/logo.svg';
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 border-b border-transparent transition-colors duration-300"
>
  <nav class="container flex h-16 items-center md:gap-10">
    <div class="flex items-center justify-center gap-x-4 lg:gap-x-10">
      <a href={homePath} class="shrink-0">
        <img
          src={logoSrc}
          alt="Logo"
          width={35}
          height={35}
          decoding="async"
        />
      </a>

      <ul
        class="hidden items-center gap-x-1 justify-self-start text-sm font-medium md:flex lg:gap-10"
      >
        <NavLinks
          client:idle
          labels={navLabels}
          homePath={homePath}
          showProjects={showProjects}
        />
      </ul>
    </div>

    <div class="flex flex-1 items-center justify-end gap-x-1.5">
      <LocaleToggle
        client:idle
        labels={localeLabels}
        currentLocale={locale}
      />
      <ThemeToggle client:idle labels={themeLabels} />
      <MobileNav
        client:idle
        labels={navLabels}
        homePath={homePath}
        logoSrc={logoSrc}
        showProjects={showProjects}
      />
    </div>
  </nav>
</header>

---
import Reveal from '~/components/astro/Reveal.astro';

import { cn } from '~/lib/utils';

interface Props {
  class?: string;
  id?: string;
  skipFadeIn?: boolean;
  variant?: 'default' | 'muted';
  innerWrapperClassName?: string;
}

const {
  class: className,
  id,
  skipFadeIn = false,
  variant = 'default',
  innerWrapperClassName,
} = Astro.props;
---

<section
  id={id}
  data-watched={id ? 'true' : undefined}
  class={cn(
    'py-16 md:py-28',
    variant === 'muted' && 'bg-muted/40',
    className
  )}
>
  {
    skipFadeIn ? (
      <div class={cn('container', innerWrapperClassName)}>
        <slot />
      </div>
    ) : (
      <Reveal
        type="slide-up"
        distance={200}
        class={cn('container', innerWrapperClassName)}
      >
        <slot />
      </Reveal>
    )
  }
</section>

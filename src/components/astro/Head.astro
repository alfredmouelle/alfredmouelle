---
import JsonLd from '~/components/astro/JsonLd.astro';

import { AppConfig } from '~/app.config';
import { personSchema, websiteSchema } from '~/lib/jsonld';
import { LOCALES, type Locale } from '~/locales';

interface Props {
  locale: Locale;
  pathname: string;
  title?: string;
  description?: string;
  canonical?: string;
  keywords?: string[];
  ogType?: 'website' | 'article';
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const meta = AppConfig.metadata[Astro.props.locale];
const title = Astro.props.title ?? meta.title;
const description = Astro.props.description ?? meta.description;
const keywords = Astro.props.keywords ?? meta.keywords;
const ogType = Astro.props.ogType ?? meta.ogType;
const ogImage = new URL(
  Astro.props.ogImage ?? meta.ogImage,
  AppConfig.domain
).toString();
const ogImageWidth = Astro.props.ogImageWidth ?? 2400;
const ogImageHeight = Astro.props.ogImageHeight ?? 1260;
const noindex = Astro.props.noindex ?? !meta.robots.index;

const localePathFor = (target: Locale): string => {
  const segments = Astro.props.pathname.split('/').filter(Boolean);
  segments[0] = target;
  return `/${segments.join('/')}${Astro.props.pathname.endsWith('/') ? '/' : ''}`;
};

const canonical =
  Astro.props.canonical ??
  new URL(localePathFor(Astro.props.locale), AppConfig.domain).toString();

const baseSchemas = [
  personSchema(Astro.props.locale),
  websiteSchema(Astro.props.locale),
];
const extraSchemas = Astro.props.jsonLd
  ? Array.isArray(Astro.props.jsonLd)
    ? Astro.props.jsonLd
    : [Astro.props.jsonLd]
  : [];
const schemas = [...baseSchemas, ...extraSchemas];
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<meta
  name="theme-color"
  content="#fdfdfc"
  media="(prefers-color-scheme: light)"
/>
<meta
  name="theme-color"
  content="#0a0f1a"
  media="(prefers-color-scheme: dark)"
/>

<link rel="preconnect" href="https://github.com" crossorigin />
<link rel="dns-prefetch" href="https://github.com" />
<link rel="dns-prefetch" href="https://www.linkedin.com" />

<title>{title}</title>
<meta name="description" content={description} />
<meta name="keywords" content={keywords.join(', ')} />
<meta name="author" content={AppConfig.author.name} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<meta
  name="google-site-verification"
  content={meta.googleVerification}
/>

<link rel="canonical" href={canonical} />
{
  LOCALES.map((alt) => (
    <link
      rel="alternate"
      hreflang={alt}
      href={new URL(localePathFor(alt), AppConfig.domain).toString()}
    />
  ))
}
<link
  rel="alternate"
  hreflang="x-default"
  href={new URL(
    localePathFor(AppConfig.defaultMetadataLocale),
    AppConfig.domain
  ).toString()}
/>

<link rel="icon" href={meta.icons.favicon} sizes="any" />
<link rel="icon" type="image/svg+xml" href={meta.icons.svg} />
<link rel="apple-touch-icon" href={meta.icons.apple} />
<link rel="manifest" href={meta.manifest} />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={AppConfig.siteName} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content={String(ogImageWidth)} />
<meta property="og:image:height" content={String(ogImageHeight)} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:site" content={meta.twitter.site} />
<meta name="twitter:creator" content={meta.twitter.creatorId} />

<JsonLd schema={schemas} />

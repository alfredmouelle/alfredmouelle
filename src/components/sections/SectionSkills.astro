---
import Section from '~/components/astro/Section.astro';
import SectionHeader from '~/components/astro/SectionHeader.astro';
import Reveal from '~/components/astro/Reveal.astro';
import { Icons } from '~/components/icons';
import {
  Card,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from '~/components/ui/card';

import { createScopedTranslator, normalizeLocale } from '~/locales';

const locale = normalizeLocale(Astro.currentLocale);
const t = createScopedTranslator(locale, 'section_skills');

const skills = [
  {
    title: 'Backend',
    Icon: Icons.server,
    details: t('backend_desc'),
    mainSkills: ['Node.js', 'Spring Boot', 'Laravel'],
  },
  {
    title: 'Frontend',
    Icon: Icons.layout,
    details: t('frontend_desc'),
    mainSkills: ['Next.js', 'TanStack Start', 'Astro', 'Angular', 'Tailwind CSS'],
  },
  {
    title: 'Mobile',
    Icon: Icons.smartphone,
    details: t('mobile_desc'),
    mainSkills: ['Flutter', 'React Native'],
  },
  {
    title: 'Database',
    Icon: Icons.database,
    details: t('database_desc'),
    mainSkills: ['PostgreSQL', 'MongoDB', 'Prisma', 'Drizzle', 'Redis'],
  },
  {
    title: 'DevOps & Tools',
    Icon: Icons.tools,
    details: t('devops_desc'),
    mainSkills: ['Docker', 'Vercel', 'GitHub Actions', 'AWS S3', 'Git'],
  },
  {
    title: 'Testing',
    Icon: Icons.tests,
    details: t('tests_desc'),
    mainSkills: ['Cypress', 'Vitest', 'Playwright'],
  },
] as const;
---

<Section id="skills">
  <SectionHeader
    eyebrow={t('eyebrow')}
    title={t('title')}
    description={t('description')}
  />

  <ul class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {
      skills.map((skill, index) => (
        <Reveal
          as="li"
          type="slide-up"
          delay={index * 60}
          class="col-span-full md:col-span-1"
        >
          <Card className="group flex h-full flex-col transition duration-300 ease-out hover:-translate-y-1 hover:border-primary/40 hover:shadow-float">
            <CardHeader className="flex-grow">
              <div class="mb-3 flex size-11 items-center justify-center rounded-xl border border-border/70 bg-muted/60 text-primary transition-colors group-hover:border-primary/40 group-hover:bg-primary/10">
                <skill.Icon className="size-5" />
              </div>
              <CardTitle className="text-base">{skill.title}</CardTitle>
              <CardDescription className="mt-2 leading-relaxed">
                {skill.details}
              </CardDescription>
            </CardHeader>

            <CardFooter>
              <ul class="flex w-full flex-wrap items-center gap-1.5">
                {skill.mainSkills.map((s) => (
                  <li class="shrink-0 rounded-full border border-border/70 bg-background px-2.5 py-0.5 text-xs text-muted-foreground transition-colors group-hover:border-primary/30 group-hover:text-foreground">
                    {s}
                  </li>
                ))}
              </ul>
            </CardFooter>
          </Card>
        </Reveal>
      ))
    }
  </ul>
</Section>

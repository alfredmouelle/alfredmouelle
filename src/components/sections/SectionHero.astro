---
import { Image } from 'astro:assets';
import { getRelativeLocaleUrl } from 'astro:i18n';

import Section from '~/components/astro/Section.astro';
import TypewriterText from '~/components/animations/typewritter-text';
import { ContactButton } from '~/components/islands/contact-button';
import { DownloadCvButton } from '~/components/islands/download-cv-button';

import heroAvatar from '~/assets/hero-avatar.webp';
import { AppConfig } from '~/app.config';
import { createScopedTranslator, normalizeLocale } from '~/locales';

const locale = normalizeLocale(Astro.currentLocale);
const avatarAlt = `${AppConfig.author.name} — ${AppConfig.author.jobTitle[locale]}`;
const t = createScopedTranslator(locale, 'section_hero');
const tNav = createScopedTranslator(locale, 'navbar');
const homePath = getRelativeLocaleUrl(locale, '/');

const techs = [
  'Next.js',
  'TypeScript',
  'Angular',
  'Node.js',
  'Spring Boot',
  'PostgreSQL',
  'React Native',
];
---

<Section
  id="section_hero"
  skipFadeIn
  class="mt-20 overflow-hidden"
>
  <div
    class="hero grid min-h-[calc(100vh-22rem)] items-center gap-10 md:grid-cols-5 md:gap-6"
  >
    <div
      class="order-2 flex flex-col items-center gap-y-5 text-center md:order-none md:col-span-3 md:items-start md:text-left"
    >
      <span class="eyebrow text-muted-foreground">{t('greetings')}</span>

      <h1
        class="font-display text-[clamp(2.5rem,6vw,4.25rem)] text-foreground"
      >
        Alfred Mouelle
      </h1>

      <div
        class="flex w-fit items-center gap-x-0.5 rounded-full border border-border/70 bg-card px-4 py-1.5 text-sm font-medium text-primary shadow-soft"
      >
        <span>{'<'}</span>
        <TypewriterText client:idle text={t('position')} className="font-medium" />
        <span>{'/>'}</span>
      </div>

      <p class="max-w-xl text-pretty leading-relaxed text-muted-foreground">
        {t('description')}
      </p>

      <div
        class="z-10 mt-2 flex w-full flex-col flex-wrap items-center gap-3 sm:flex-row md:justify-start"
      >
        <DownloadCvButton client:idle label={t('downloadCvBtn')} locale={locale} />
        <ContactButton client:idle label={tNav('links.contact')} homePath={homePath} />
      </div>

      <ul
        class="mt-3 flex flex-wrap items-center justify-center gap-x-2 gap-y-1.5 text-xs text-muted-foreground md:justify-start"
      >
        {
          techs.map((tech, i) => (
            <li class="flex items-center gap-2">
              {i > 0 ? <span class="text-border">&middot;</span> : null}
              <span>{tech}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="order-1 flex justify-center md:order-none md:col-span-2 md:justify-end">
      <div class="relative">
        <div class="rounded-full bg-card p-2 shadow-soft ring-1 ring-border">
          <Image
            src={heroAvatar}
            alt={avatarAlt}
            width={500}
            height={500}
            widths={[320, 500, 800]}
            sizes="(max-width: 768px) 70vw, 420px"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="size-64 rounded-full bg-background object-cover sm:size-72 md:size-80"
          />
        </div>

        <div
          class="absolute -bottom-3 left-1/2 flex -translate-x-1/2 items-center gap-2 whitespace-nowrap rounded-full border border-border/70 bg-card/70 px-4 py-2 shadow-float backdrop-blur-xl"
        >
          <span class="relative flex size-2">
            <span
              class="absolute inline-flex size-full animate-ping rounded-full bg-green-500/60"
            ></span>
            <span class="relative inline-flex size-2 rounded-full bg-green-500"></span>
          </span>
          <span class="text-xs font-medium text-foreground">{t('availability')}</span>
        </div>
      </div>
    </div>
  </div>
</Section>

---
import Section from '~/components/astro/Section.astro';
import SectionHeader from '~/components/astro/SectionHeader.astro';
import Reveal from '~/components/astro/Reveal.astro';

import { createScopedTranslator, normalizeLocale } from '~/locales';

const locale = normalizeLocale(Astro.currentLocale);
const t = createScopedTranslator(locale, 'section_scholarship');

const entries = [
  {
    title: t('bts.title'),
    specialty: t('bts.specialty'),
    period: '2018 — 2020',
    place: t('bts.academy'),
    location: t('bts.location'),
  },
  {
    title: t('bac.title'),
    specialty: t('bac.specialty'),
    period: '2017 — 2018',
    place: t('bac.location1'),
    location: t('bac.location2'),
  },
  {
    title: t('probatoire.title'),
    specialty: t('bac.specialty'),
    period: '2016 — 2017',
    place: t('bac.location1'),
    location: t('bac.location2'),
  },
] as const;
---

<Section id="scholarship" variant="muted">
  <SectionHeader eyebrow={t('eyebrow')} title={t('title')} />

  <Reveal type="slide-up" class="relative max-w-2xl">
    <div
      class="absolute bottom-2 left-[7px] top-2 w-px bg-border"
      aria-hidden="true"
    >
    </div>

    <ol class="space-y-10">
      {
        entries.map((entry, index) => (
          <Reveal as="li" type="slide-up" delay={index * 80} class="relative pl-8">
            <span
              class="absolute left-0 top-1.5 size-3.5 rounded-full border-2 border-background bg-primary shadow-soft"
              aria-hidden="true"
            />
            <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
              <h3 class="font-display text-lg tracking-tight">{entry.title}</h3>
              <span class="text-sm tabular-nums text-muted-foreground">
                {entry.period}
              </span>
            </div>
            <p class="mt-0.5 text-sm font-medium text-primary">{entry.specialty}</p>
            <p class="mt-2 text-sm text-muted-foreground">{entry.place}</p>
            <p class="text-sm text-muted-foreground">{entry.location}</p>
          </Reveal>
        ))
      }
    </ol>
  </Reveal>
</Section>

---
import Reveal from '~/components/astro/Reveal.astro';
import Section from '~/components/astro/Section.astro';
import SectionHeader from '~/components/astro/SectionHeader.astro';
import { Icon, Icons } from '~/components/icons';
import { ContactForm } from '~/components/islands/contact-form';

import { createScopedTranslator, normalizeLocale } from '~/locales';

const locale = normalizeLocale(Astro.currentLocale);
const t = createScopedTranslator(locale, 'section_contact');

const socials = [
  {
    Icon: Icons.github,
    label: 'GitHub',
    url: 'https://github.com/alfredmouelle',
  },
  {
    Icon: Icons.linkedin,
    label: 'LinkedIn',
    url: 'https://www.linkedin.com/in/alfredmouelle',
  },
  { Icon: Icons.twitter, label: 'X', url: 'https://twitter.com/kali47_' },
  {
    Icon: Icons.website,
    label: 'ComeUp',
    url: 'https://comeup.com/fr/@alfredmouelle',
  },
  {
    Icon: Icons.whatsapp,
    label: 'WhatsApp',
    url: 'https://api.whatsapp.com/send?phone=237693692721',
  },
] as const;

const formLabels = {
  fields: {
    name: t('form.fields.name'),
    email: t('form.fields.email'),
    subject: t('form.fields.subject'),
    message: t('form.fields.message'),
    submit: t('form.fields.submit'),
  },
  errors: {
    name: t('form.errors.name'),
    email: t('form.errors.email'),
    subject: t('form.errors.subject'),
    message: t('form.errors.message'),
  },
  placeholders: {
    subject: t('form.placeholders.subject'),
  },
  messages: {
    success: t('form.messages.success'),
    error: t('form.messages.error'),
  },
};
---

<Section id="contact">
  <div class="grid items-start gap-12 lg:grid-cols-2 lg:gap-16">
    <Reveal type="slide-up">
      <SectionHeader
        eyebrow={t('eyebrow')}
        title={t('title')}
        description={t('description')}
        class="mb-0 max-w-md"
      />

      <a
        data-contact-email
        class="group mt-8 flex w-fit items-center gap-3 text-lg font-medium"
      >
        <span
          class="flex size-10 shrink-0 items-center justify-center rounded-full border border-border/70 bg-card text-primary shadow-soft transition-colors group-hover:border-primary/40 group-hover:bg-primary/5"
        >
          <Icon name="mail" className="size-4" />
        </span>
        <span
          data-email-label
          class="break-all transition-colors group-hover:text-primary"
        ></span>
      </a>

      <ul class="mt-8 flex flex-wrap items-center gap-2.5">
        {
          socials.map((c) => (
            <li>
              <a
                target="_blank"
                href={c.url}
                rel="noopener noreferrer"
                class="group flex items-center gap-2 rounded-full border border-border/70 bg-card px-3.5 py-2 text-sm text-muted-foreground shadow-soft transition-all hover:-translate-y-0.5 hover:border-primary/40 hover:text-foreground"
              >
                <c.Icon className="size-4 transition-colors group-hover:text-primary" />
                {c.label}
              </a>
            </li>
          ))
        }
      </ul>
    </Reveal>

    <Reveal
      type="slide-up"
      delay={80}
      class="rounded-2xl border border-border/70 bg-card p-6 shadow-soft md:p-8"
    >
      <ContactForm client:visible labels={formLabels} />
    </Reveal>
  </div>
</Section>

<script>
  const address = ['alfredmouelle', 'gmail.com'].join('@');
  const link = document.querySelector<HTMLAnchorElement>('[data-contact-email]');

  if (link) {
    link.href = `mailto:${address}`;
    const label = link.querySelector<HTMLElement>('[data-email-label]');
    if (label) label.textContent = address;
  }
</script>

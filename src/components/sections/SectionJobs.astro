---
import { getRelativeLocaleUrl } from 'astro:i18n';

import Section from '~/components/astro/Section.astro';
import SectionHeader from '~/components/astro/SectionHeader.astro';
import Reveal from '~/components/astro/Reveal.astro';
import { Icon } from '~/components/icons';
import { JobCard } from '~/components/job-card';
import { buttonVariants } from '~/components/ui/button';

import { getJobs, getJobSlug } from '~/lib/jobs';
import { createScopedTranslator, normalizeLocale } from '~/locales';
import { cn } from '~/lib/utils';

const locale = normalizeLocale(Astro.currentLocale);
const t = createScopedTranslator(locale, 'section_jobs');
const tJob = createScopedTranslator(locale, 'job');
const tPeriod = createScopedTranslator(locale, 'job.period');

const labels = {
  readTime: tJob('readTime'),
  elapsed: tPeriod('elapsed'),
  from: tPeriod('from'),
  to: tPeriod('to'),
};

const all = await getJobs(locale);
const featured = all.find((j) => j.data.featured);
const display = featured
  ? [featured, ...all.filter((j) => j !== featured).slice(0, 2)]
  : all.slice(0, 3);
---

<Section id="jobs">
  <SectionHeader
    eyebrow={t('eyebrow')}
    title={t('title')}
    description={t('description')}
  />

  <ul class="grid gap-4 md:grid-cols-3">
    {
      display.map((job, index) => (
        <Reveal
          as="li"
          type="slide-up"
          delay={index * 60}
          class="col-span-3 md:col-span-1"
        >
          <a
            href={getRelativeLocaleUrl(locale, `/jobs/${getJobSlug(job)}`)}
            class="block h-full"
          >
            <JobCard job={job.data} locale={locale} labels={labels} />
          </a>
        </Reveal>
      ))
    }
  </ul>

  <div class="mt-8 flex justify-center">
    <a
      href={getRelativeLocaleUrl(locale, '/jobs')}
      class={cn('group', buttonVariants({ variant: 'outline' }))}
    >
      {t('showJobs')}
      <Icon
        name="arrowRight"
        className="size-4 transition-transform group-hover:translate-x-0.5"
      />
    </a>
  </div>
</Section>

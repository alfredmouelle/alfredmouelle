---
import { getRelativeLocaleUrl } from 'astro:i18n';

import ProjectCard from '~/components/astro/ProjectCard.astro';
import Reveal from '~/components/astro/Reveal.astro';
import Section from '~/components/astro/Section.astro';
import SectionHeader from '~/components/astro/SectionHeader.astro';
import {
  Breadcrumb,
  BreadcrumbItem,
  BreadcrumbList,
  BreadcrumbPage,
  BreadcrumbSeparator,
} from '~/components/ui/breadcrumb';

import { AppConfig } from '~/app.config';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getProjectSlug, getProjects } from '~/lib/projects';
import { createScopedTranslator, LOCALES, normalizeLocale } from '~/locales';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = normalizeLocale(Astro.currentLocale);
const t = createScopedTranslator(locale, 'breadcrumb');
const tSection = createScopedTranslator(locale, 'section_projects');

const projects = await getProjects(locale);
const canonical = `${AppConfig.domain}${getRelativeLocaleUrl(locale, '/projects')}`;
---

<BaseLayout title={tSection('title')} canonical={canonical}>
  <Section class="hero mt-20" skipFadeIn>
    <Breadcrumb className="mb-6 text-sm text-muted-foreground">
      <BreadcrumbList>
        <BreadcrumbItem>
          <a
            href={getRelativeLocaleUrl(locale, '/')}
            class="transition-colors hover:text-foreground"
          >
            {t('home')}
          </a>
        </BreadcrumbItem>
        <BreadcrumbSeparator />
        <BreadcrumbItem>
          <BreadcrumbPage>{t('projects')}</BreadcrumbPage>
        </BreadcrumbItem>
      </BreadcrumbList>
    </Breadcrumb>

    <SectionHeader
      eyebrow={tSection('eyebrow')}
      title={tSection('title')}
      description={tSection('description')}
    />

    <ul class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        projects.map((project, index) => (
          <Reveal as="li" type="slide-up" delay={index * 60}>
            <ProjectCard
              project={project.data}
              href={getRelativeLocaleUrl(locale, `/projects/${getProjectSlug(project)}`)}
            />
          </Reveal>
        ))
      }
    </ul>
  </Section>
</BaseLayout>
